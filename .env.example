# ─── Postgres (Neon / Supabase) ───
DATABASE_URL=postgresql://user:pass@host:5432/birdeye?sslmode=require

# ─── Upstash Redis ───
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx

# ─── Upstash QStash (scheduler) ───
QSTASH_TOKEN=qs_xxxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxxx
QSTASH_NEXT_SIGNING_KEY=sig_xxxx

# ─── Amazon PAAPI5 (optional – enables API-first path) ───
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_MARKETPLACE=www.amazon.in

# ─── Flipkart Affiliate API (optional) ───
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=

# ─── Notifications ───
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx
RESEND_API_KEY=re_xxxx
NOTIFY_EMAIL_FROM=alerts@yourdomain.com
NOTIFY_EMAIL_TO=team@yourdomain.com

# ─── App ───
CRON_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_APP_URL=https://bird-eye.vercel.app
