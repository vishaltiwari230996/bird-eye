# ─── Postgres (Neon / Supabase) ───
DATABASE_URL=postgresql://user:pass@host:5432/birdeye?sslmode=require

# ─── BrightData managed Amazon scraper ───
# Sign up at brightdata.com and create two datasets:
#   * "Amazon Product"          → BRIGHTDATA_DATASET_ID (mandatory)
#   * "Amazon Sellers Info"     → BRIGHTDATA_SELLERS_DATASET_ID (recommended)
# Without the sellers dataset only the buy-box seller is captured per SKU.
BRIGHTDATA_TOKEN=your-brightdata-bearer-token
BRIGHTDATA_DATASET_ID=gd_l7q7dkf244hwjntr0
BRIGHTDATA_SELLERS_DATASET_ID=

# Anchor city so Amazon doesn't shuffle the buy-box by region between scrapes.
BRIGHTDATA_ZIPCODE=400001

# ─── BrightData residential proxy (Snapshots panel) ───
# The Snapshots panel drives Playwright through this proxy to capture hourly
# page-screenshots like a human. Without it Amazon will captcha-wall the
# datacenter IPs of HF Space / Cloud Run.
PROXY_URL=
PROXY_VERIFY_SSL=false

# ─── App ───
CRON_SECRET=change-me-to-a-long-random-string
# Snapshots panel — how many PW SKUs to capture each hour (default 40).
SNAPSHOT_LIMIT=40

# ─── AI (OpenRouter) — optional, powers the Report page narrative ───
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# ─── Frontend ───
NEXT_PUBLIC_APP_URL=https://bird-eye.vercel.app
